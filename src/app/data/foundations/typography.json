{
  "page": "Typography",
  "path": "/hds/foundations/typography",
  "definition": {
    "id": "typography",
    "category": "foundation",
    "summary": "Typography is a closed system: one body font, one mono font, and a fixed set of semantic composite tokens."
  },
  "rules": [
    {
      "id": "one-typeface",
      "rule": "Use Satoshi for body and UI text only. Clash Display is reserved for display, h1, h2, h3 headings.",
      "enforceable": false,
      "valid": "fontFamily: hds.fontFamily",
      "invalid": "fontFamily: 'Georgia, serif'"
    },
    {
      "id": "semantic-composite",
      "rule": "Use semantic.typography.* composites for text styling instead of raw font values.",
      "enforceable": true,
      "valid": "style={hds.typeStyles.body}",
      "invalid": "style={{ fontSize: 16, fontWeight: 400 }}"
    },
    {
      "id": "no-tailwind-font",
      "rule": "Skip Tailwind font utilities. Use hds.typeStyles.* inline style objects.",
      "enforceable": true,
      "valid": "style={hds.typeStyles.h1}",
      "invalid": "className='text-xl font-semibold'"
    },
    {
      "id": "mono-scope",
      "rule": "Use Geist Mono for token chips, inline code, file paths, and technical metadata.",
      "enforceable": false,
      "valid": "<InlineCode>{tokenPath}</InlineCode>",
      "invalid": "<p style={hds.typeStyles.mono}>See our documentation</p>"
    }
  ],
  "usage": [
    {
      "condition": "Hero headlines and landing-page displays",
      "apply": "hds.typeStyles.display"
    },
    {
      "condition": "Primary section headings (h1)",
      "apply": "hds.typeStyles.h1"
    },
    {
      "condition": "Secondary section headings (h2)",
      "apply": "hds.typeStyles.h2"
    },
    {
      "condition": "Tertiary headings or card titles (h3)",
      "apply": "hds.typeStyles.h3"
    },
    {
      "condition": "Body text for long-form prose",
      "apply": "hds.typeStyles.body"
    },
    {
      "condition": "Standard interface text: sidebars, nav, labels, inputs",
      "apply": "hds.typeStyles.small"
    },
    {
      "condition": "Helper text, secondary metadata, form annotations",
      "apply": "hds.typeStyles.caption"
    },
    {
      "condition": "Code snippets, token names, keyboard shortcuts, technical metadata",
      "apply": "hds.typeStyles.mono"
    },
    {
      "condition": "Status badges and tags",
      "apply": "hds.typeStyles.caption"
    }
  ],
  "examples": [
    {
      "name": "BODY COPY - React inline style",
      "code": "<p style={{ ...hds.typeStyles.body, fontFamily: hds.fontFamily, color: 'var(--semantic-color-content-primary)' }}>\n  All prose uses hds.typeStyles.body - no class overrides.\n</p>",
      "tokensUsed": [
        "semantic.typography.body",
        "semantic.color.content.primary"
      ]
    },
    {
      "name": "HEADING - React inline style",
      "code": "<h2 style={{ ...hds.typeStyles.h2, fontFamily: hds.fontFamily, color: 'var(--semantic-color-content-primary)' }}>\n  Sub-section title\n</h2>",
      "tokensUsed": [
        "semantic.typography.h2"
      ]
    },
    {
      "name": "LABEL - React inline style",
      "code": "<p style={{ ...hds.typeStyles.small, fontFamily: hds.fontFamily, color: 'var(--semantic-color-content-secondary)' }}>\n  On this page\n</p>",
      "tokensUsed": [
        "semantic.typography.small",
        "primitive.typography.size.sm",
        "primitive.typography.weight.medium",
        "primitive.typography.letterSpacing.wide",
        "primitive.typography.lineHeight.none"
      ]
    },
    {
      "name": "CSS VAR EXPANSION - semantic composite",
      "code": "/* Each semantic.typography.* expands to 5 CSS custom properties */\n--semantic-typography-display-fontFamily\n--semantic-typography-display-fontSize\n--semantic-typography-display-fontWeight\n--semantic-typography-display-letterSpacing\n--semantic-typography-display-lineHeight",
      "tokensUsed": [
        "semantic.typography.display"
      ]
    }
  ],
  "mappings": [
