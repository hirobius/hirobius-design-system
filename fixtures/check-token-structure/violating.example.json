{
  "primitive": {
    "color": {
      "$type": "color",
      "white": { "$value": "#ffffff" },
      "black": { "$value": "#000000" }
    }
  },
  "semantic": {
    "color": {
      "$type": "color",
      "surface": { "$value": "{primitive.color.white}" },
      "ink": { "$value": "{primitive.color.black}" },
      "surface-alt": { "$value": "{semantic.color.surface}" }
    }
  },
  "component": {
    "button": {
      "color": {
        "$type": "color",
        "bg": { "$value": "{semantic.color.surface}" }
      }
    }
  }
}
