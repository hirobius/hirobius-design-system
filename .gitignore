node_modules/
dist/
temp/
.ssr-cache/
.DS_Store
*.local

# Vitest coverage HTML report (full artifacts) — only coverage-summary.json in tests/ is tracked
coverage/

# Generated CycloneDX SBOM (regenerate via `pnpm audit:sbom`; not committed)
docs/security/sbom.json

# Storybook static build output
storybook-static/

# Environment & secrets — never commit
.env
.env.*
!.env.example
*.pem
*.key
.vercel

# HDS batch scan output (generated at runtime; not committed)
scans/
docs/visual-catalog/

# Figma masters batch snapshots (generated by pipeline/figma-masters-batch.mjs --emit)
pipeline/output/

.vercel
.claude/launch.json
vite-dev.err.log
vite-dev.out.log
.codex-dev.err
.codex-dev.log
.codex
_tmp_*
vite-actions-check.log
*.patch
test-results/
telemetry/events.jsonl
telemetry/test-events.jsonl

# p6-4: reverse-token-sync output. Bridge writes the latest Figma
# Variables snapshot here for human diff before any merge into
# hirobius.tokens.json or public/hds-manifest.json. Not committed.
tokens-from-figma.json

# Claude Code worktrees (per-session sandboxes — not tracked)
.claude/worktrees/
.claude/settings.local.json

# Overnight burndown coordination — regenerated by scripts/orchestration-watcher.mjs
docs/ai/ready-queue.json

# Orchestration snapshots — local recovery points, not history
# Daily by scripts/snapshot-orchestration.mjs; one-shot pre-compact snapshots
# by scripts/compact-done-units.py. Git history of orchestration.json itself
# is the canonical change record.
docs/ai/snapshots/

# Lean agent manifest projection — regenerated by scripts/generate-manifest-projection.mjs
public/hds-manifest-agent.json

# Lighthouse CI run artifacts (local reports, not tracked)
.lighthouseci/
# Windows Lighthouse temp dirs (WSL2 cross-process chrome debug logs).
# Backslashes must be escaped in gitignore — these are literal filename
# bytes (WSL2 + Windows-Chrome treats `C:\Users\...` as one filename).
/C:\\*
# Kimi-agent drain-notify throttle state (local-only, regenerates per host).
docs/ai/.kimi-drain-state.json
.youtube-oauth-client.json
.youtube-token-*.json

# Runtime/lock scratch (added during pre-deploy bundling 2026-05-03)
.claude/scheduled_tasks.lock
test-results/.last-run.json
docs/ai/swarm-watchdog.log
docs/ai/swarm-watchdog-pulse.log
docs/ai/proposed-units.jsonl
docs/ai/proposed-skills.jsonl

# mtime-scoped proof-of-firing cache — regenerated by scripts/validate-fixture-proof-of-firing.mjs
.fixture-proof-cache.json

# Post-commit gate firing log (13g-12) — operational audit data, regenerated locally on every commit
docs/guardrails/firing-log.jsonl
docs/guardrails/firing-log.stderr

# Per-client automation runtime logs — appended by automations/<id>/run.mjs
clients/*/automations/_log.jsonl

# Per-client inbox discovery output — may contain tenant-specific summaries
clients/*/inbox-discovery-results/

# Local agent state — never committed
.agents/
.claude/skills/
.worktrees/

# Bundle visualizer output (generated by `pnpm audit:bundle` via vite-bundle-visualizer)
docs/perf/bundle-report.html

# Local knowledge corpus (gitignored). Anchored to the repo root so it does not
# also swallow src/app/data/, which holds tracked design-system source data
# (foundation files, nav/editorial modules, the page registry).
/data/

# src/app/data: source files (foundations/*, hds-nav-data, hdsEditorial,
# tenants, projects, hds-registry, tokenAuditReportTypes) ARE tracked. The
# files below are regenerated by the build pipeline — keep them untracked.
src/app/data/component-api.json
src/app/data/roadmap.json
src/app/data/used-icons.json
src/app/data/health-history.json
src/app/data/security-posture.json
src/app/data/commit-history.json

# Figma variable exports — ~410KB of artifacts deterministically generated from
# hirobius.tokens.json by scripts/build-figma-variables.mjs (run via
# `pnpm figma-variables`). Not source, not shipped to consumers, and no
# automatic gate depends on them (audit-figma-system is manual/warn). The
# sync-figma-variables CI workflow regenerates them before pushing to the Figma
# REST API, so a committed copy is redundant. Regenerate on demand.
hirobius.figma-variables.json
hirobius.figma-variables-api.json

# Auto-research findings — local LLM output, regenerated each run
# (queries.json itself IS tracked; only the per-run findings are local-only)
docs/research/findings/

# One-shot artifacts (never track)
*.log
*.bak
*.tmp
*-report.json
