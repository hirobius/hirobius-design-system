{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": false,
    "resolveJsonModule": true,
    "isolatedModules": false,
    "skipLibCheck": true,
    "noEmit": true,
    "strict": true,
    "ignoreDeprecations": "6.0",
    "noUnusedLocals": false,
    "baseUrl": "../..",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["*.test-d.ts"],
  "exclude": ["../../node_modules"]
}
