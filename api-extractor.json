{
  "$schema": "https://developer.microsoft.com/json-schemas/api-extractor/v7/api-extractor.schema.json",

  "mainEntryPointFilePath": "<projectFolder>/temp/api-extractor-tsbuild/src/index.d.ts",

  "bundledPackages": [],

  "compiler": {
    "tsconfigFilePath": "<projectFolder>/tsconfig.api-extractor.json",
    "overrideTsconfig": {
      "compilerOptions": {
        "moduleResolution": "Node",
        "noEmit": false,
        "declaration": true,
        "emitDeclarationOnly": true,
        "outDir": "./temp/api-extractor-tsbuild",
        "skipLibCheck": true
      }
    }
  },

  "apiReport": {
    "enabled": false,
    "reportFolder": "<projectFolder>/temp/"
  },

  "docModel": {
    "enabled": false
  },

  "dtsRollup": {
    "enabled": false
  },

  "tsdocMetadata": {
    "enabled": false
  },

  "messages": {
    "compilerMessageReporting": {
      "default": {
        "logLevel": "none"
      }
    },
    "extractorMessageReporting": {
      "default": {
        "logLevel": "warning"
      },
      "ae-missing-release-tag": {
        "logLevel": "none"
      },
      "ae-internal-missing-underscore": {
        "logLevel": "none"
      },
      "ae-forgotten-export": {
        "logLevel": "warning"
      }
    },
    "tsdocMessageReporting": {
      "default": {
        "logLevel": "none"
      }
    }
  }
}
